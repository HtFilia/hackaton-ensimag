#!/usr/bin/env bash
# Hook git pre-commit : lance les tests publics de l'équipe avant chaque commit.
# Installez-le avec : make register

echo ""
echo "  ⚡ Flash Trading — vérification avant commit..."
echo ""

if [ ! -f ".team" ] || [ -z "$(cat .team)" ]; then
    echo "  ✗ Équipe non définie. Lancez 'make register' avant de committer."
    echo ""
    exit 1
fi

TEAM=$(cat .team)
echo "  Équipe : $TEAM"
echo ""

TEST_OUTPUT=$(HACKATHON_TEAM="$TEAM" python3 -m pytest tests/levels/ -q --tb=line 2>&1)
EXIT_CODE=$?

echo "$TEST_OUTPUT"

# Aucun test collecté (équipe fraîchement créée, pas encore dans une CI)
if [ $EXIT_CODE -eq 5 ]; then
    echo ""
    echo "  ✓ Aucun test à vérifier pour l'instant."
    echo ""
    exit 0
fi

# Tous les tests passent
if [ $EXIT_CODE -eq 0 ]; then
    echo ""
    echo "  ✓ Tous les tests passent."
    echo ""
    exit 0
fi

# Des tests échouent — distinguer NotImplementedError des vraies erreurs
REAL_FAILURES=$(echo "$TEST_OUTPUT" | grep "^FAILED" | grep -v "NotImplementedError")

if [ -z "$REAL_FAILURES" ]; then
    echo ""
    echo "  ✓ Paliers non encore implémentés — commit autorisé."
    echo ""
    exit 0
fi

# Vraies erreurs : demander confirmation
echo ""
echo "  ⚠ Des tests échouent (hors paliers non implémentés)."
printf "    Voulez-vous quand même committer ? [y/N] "
read -r REPLY </dev/tty
echo ""
if [[ "$REPLY" =~ ^[Yy]$ ]]; then
    echo "  → Commit effectué malgré les échecs."
    echo ""
    exit 0
else
    echo "  → Commit annulé. Corrigez les erreurs et relancez git commit."
    echo ""
    exit 1
fi
