#!/usr/bin/env bash
# Hook git pre-commit : lance les tests publics de l'équipe avant chaque commit.
# Installez-le avec : make register

echo ""
echo "  ⚡ Flash Trading — vérification avant commit..."
echo ""

if [ ! -f ".team" ] || [ -z "$(cat .team)" ]; then
    echo "  ✗ Équipe non définie. Lancez 'make register' avant de committer."
    echo ""
    exit 1
fi

TEAM=$(cat .team)
echo "  Équipe : $TEAM"
echo ""
HACKATHON_TEAM="$TEAM" python3 -m pytest tests/levels/ -q --tb=short 2>&1

EXIT_CODE=$?

# Exit code 5 = aucun test collecté (équipe sans fixtures encore) → OK
if [ $EXIT_CODE -eq 5 ]; then
    echo ""
    echo "  ✓ Aucun test à vérifier pour l'instant."
    echo ""
    exit 0
fi

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "  ⚠ Des tests échouent."
    printf "    Voulez-vous quand même committer ? [y/N] "
    read -r REPLY </dev/tty
    echo ""
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        echo "  → Commit forcé malgré les tests en échec."
        echo ""
        exit 0
    else
        echo "  → Commit annulé. Corrigez les erreurs et relancez git commit."
        echo ""
        exit 1
    fi
fi

echo ""
echo "  ✓ Tous les tests passent."
echo ""
exit 0
